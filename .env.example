# ── Telegram ──────────────────────────────────────────────────────────────────
MA_TELEGRAM_BOT_TOKEN=your_bot_token_here
MA_TELEGRAM_CHAT_ID=your_chat_id_here

# ── AI провайдер (выберите один или оставьте пустым для режима без AI) ────────
# OpenAI GPT-4o-mini (рекомендуется для баланса цена/качество)
# MA_OPENAI_API_KEY=sk-...
# MA_AI_PROVIDER=openai
# MA_AI_MODEL=gpt-4o-mini

# Google Gemini 1.5 Flash (самый дешёвый)
# MA_GEMINI_API_KEY=AIza...
# MA_AI_PROVIDER=gemini
# MA_AI_MODEL=gemini-1.5-flash

# Anthropic Claude Haiku
# MA_ANTHROPIC_API_KEY=sk-ant-...
# MA_AI_PROVIDER=anthropic
# MA_AI_MODEL=claude-haiku-4-5

# ── Сборщики ──────────────────────────────────────────────────────────────────
MA_COLLECTOR_INTERVAL_SEC=300
MA_COLLECTOR_AVITO_ENABLED=true
MA_COLLECTOR_YOULA_ENABLED=true

# ── Прокси (опционально) ──────────────────────────────────────────────────────
# MA_PROXY_URL=socks5://127.0.0.1:1080

# ── Анализатор ────────────────────────────────────────────────────────────────
MA_DEAL_SCORE_THRESHOLD_BUY=70
MA_DEAL_SCORE_THRESHOLD_MAYBE=50

# ── Дашборд ───────────────────────────────────────────────────────────────────
MA_DASHBOARD_PORT=8080

# ── Логирование ───────────────────────────────────────────────────────────────
MA_LOG_LEVEL=INFO
