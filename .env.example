# ═══════════════════════════════════════════════════════════════════
#  Market Agent v3 — SaaS Multi-User
#  .env — только инфраструктурные настройки сервера
#
#  Все пользовательские настройки (город, AI, пороги и т.д.)
#  настраиваются через Telegram-бота!
# ═══════════════════════════════════════════════════════════════════

# ── ОБЯЗАТЕЛЬНО ────────────────────────────────────────────────────
MA_TELEGRAM_BOT_TOKEN=your_bot_token_here

# ── Ваш Telegram ID (получить: @userinfobot) ───────────────────────
# Этот ID получит права администратора и доступ к /admin панели
MA_ADMIN_TELEGRAM_ID=123456789

# ── База данных ────────────────────────────────────────────────────
# MA_DB_PATH=data/market_agent.db

# ── Сервер ─────────────────────────────────────────────────────────
# MA_DASHBOARD_PORT=8080
# MA_LOG_LEVEL=INFO

# ── Playwright (парсинг) ───────────────────────────────────────────
# MA_PLAYWRIGHT_HEADLESS=true
# MA_PLAYWRIGHT_SLOW_MO=1500

# ── Прокси (опционально) ──────────────────────────────────────────
# MA_PROXY_URL=socks5://127.0.0.1:1080

# ── Глобальный AI (опционально) ───────────────────────────────────
# Если задан — используется как fallback для пользователей без AI.
# Каждый пользователь может задать свой ключ через бота.
#
# MA_WORMSOFT_API_KEY=your_key_here
# MA_AI_PROVIDER=wormsoft
# MA_AI_MODEL=wormsoft/agent/low
